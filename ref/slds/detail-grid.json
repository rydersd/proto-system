{
  "component": "detail-grid",
  "usage": "Field-value pairs in a 2-column wrapping grid. $repeat Field children.",
  "variants": {
    "base": {
      "type": "FRAME",
      "name": "DetailGrid",
      "layoutMode": "HORIZONTAL",
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "itemSpacing": 24,
      "counterAxisSpacing": 12,
      "layoutWrap": "WRAP",
      "children": [
        {
          "_comment": "$repeat: one Field per data pair. Set width to ~48% for 2-col layout.",
          "type": "FRAME",
          "name": "Field",
          "layoutMode": "VERTICAL",
          "width": 320,
          "layoutSizingVertical": "HUG",
          "itemSpacing": 2,
          "children": [
            {
              "type": "TEXT",
              "name": "Label",
              "characters": "$LABEL",
              "fontFamily": "$FONT",
              "fontSize": 10,
              "fontWeight": 700,
              "fillColor": "#5C5C5C",
              "textCase": "UPPER",
              "letterSpacing": 0.3
            },
            {
              "type": "TEXT",
              "name": "Value",
              "characters": "$VALUE",
              "fontFamily": "$FONT",
              "fontSize": 13,
              "fontWeight": 500,
              "fillColor": "#1E2A3A",
              "lineHeight": 18
            }
          ]
        }
      ]
    }
  },
  "value_variants": {
    "link": { "fillColor": "#0070D2" },
    "full_width": { "_note": "Set Field width to 100% of parent" }
  }
}
